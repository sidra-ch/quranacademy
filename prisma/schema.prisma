generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Inquiry {
  id            String   @id @default(cuid())
  parentName    String
  parentEmail   String
  childAge      String
  country       String
  whatsapp      String
  preferredTime String
  message       String
  createdAt     DateTime @default(now())
}

model TrialBooking {
  id            String   @id @default(cuid())
  parentName    String
  parentEmail   String?
  childAge      String
  country       String
  whatsapp      String
  preferredTime String?
  message       String?
  contacted     Boolean  @default(false)
  contactedAt   DateTime?
  createdAt     DateTime @default(now())
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastLoginAt  DateTime?
}

model MediaAsset {
  id               String   @id @default(cuid())
  publicId         String   @unique
  secureUrl        String
  folder           String?
  width            Int?
  height           Int?
  format           String?
  bytes            Int?
  originalFilename String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

